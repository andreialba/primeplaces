# GOOGLE_MAPS_API_KEY: Required for fetching places and rendering maps.
# Get one from Google Cloud Console.
GOOGLE_MAPS_API_KEY="YOUR_GOOGLE_MAPS_API_KEY"
VITE_GOOGLE_MAPS_API_KEY="YOUR_GOOGLE_MAPS_API_KEY"

# GEMINI_API_KEY: Required for AI features like chatbot and image generation.
# Get one from Google Cloud Console.
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# ALLOWED_ORIGINS: Comma-separated list of allowed CORS origins (optional, defaults to localhost).
# Example for production: ALLOWED_ORIGINS="https://yourdomain.com"
# ALLOWED_ORIGINS="http://localhost:3000,http://localhost:5173"
